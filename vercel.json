{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/passcodes",
      "destination": "/admin-passcodes.html"
    },
    {
      "source": "/admin/passcodes/",
      "destination": "/admin-passcodes.html"
    }
  ]
}
